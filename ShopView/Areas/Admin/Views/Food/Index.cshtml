@using ShopView.Models
@using ShopDAL.Models
@model FoodIndexViewModel

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4">
        <span class="text-muted fw-light">Admin/</span> Food Management
    </h4>
    <div class="text-end mb-4">
        <a href="/Admin/Food/Create" class="btn btn-primary">
            <i class="bx bx-plus me-1"></i> Create New Food
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="filter-form p-4 mb-4 shadow-sm rounded bg-light">
        <form method="get" asp-action="Index" class="needs-validation">
            <h4 class="mb-4 text-primary text-center fw-bold">Filter Foods</h4>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label for="Keyword" class="form-label fw-semibold text-muted">Search by Name/Description:</label>
                    <input type="text" name="keyword" id="Keyword" class="form-control" placeholder="Enter keyword" value="@Model.Filter.Keyword" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Price Range:</label>
                    <div class="input-group">
                        <input type="number" name="priceFrom" class="form-control border-end-0" placeholder="Min" value="@Model.Filter.PriceFrom" />
                        <span class="input-group-text">to</span>
                        <input type="number" name="priceTo" class="form-control border-start-0" placeholder="Max" value="@Model.Filter.PriceTo" />
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-12">
                    <label for="categoryId" class="form-label fw-semibold text-muted">Category:</label>
                    @Html.DropDownList("categoryId",
                             new SelectList(Model.Categories, "Value", "Text", Model.Filter.categoryID),
                             "All Categories",
                             new { @class = "form-select", @id = "categoryId" })
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label for="SortBy" class="form-label fw-semibold text-muted">Sort by:</label>
                    @Html.DropDownList("sortBy", new List<SelectListItem> {
                    new SelectListItem { Value = "Name", Text = "Name" },
                    new SelectListItem { Value = "Price", Text = "Price" }
                    }, "Select attribute", new { @class = "form-select", @id = "SortBy" })
                </div>
                <div class="col-md-6">
                    <label for="SortOrder" class="form-label fw-semibold text-muted">Sort Order:</label>
                    @Html.DropDownList("sortOrder", new List<SelectListItem> {
                    new SelectListItem { Value = "asc", Text = "Ascending" },
                    new SelectListItem { Value = "desc", Text = "Descending" }
                    }, "Select order", new { @class = "form-select", @id = "SortOrder" })
                </div>
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm me-2">
                    <i class="fa fa-filter"></i> Apply
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5 shadow-sm">
                    <i class="fa fa-redo"></i> Reset
                </a>
            </div>
        </form>
    </div>

    <div class="card">
        <h5 class="card-header">Food List</h5>
        <div class="table-responsive text-nowrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @if (Model.FoodItems != null)
                    {
                        @foreach (var food in Model.FoodItems)
                        {
                            <tr>
                                <td>@food.FoodItemId</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(food.ImagePath))
                                    {
                                        <img src="@(Model.ImageBaseUrl + food.ImagePath)" alt="Food Image" class="rounded" style="width: 50px; height: 50px;" />
                                    }
                                    else
                                    {
                                        <span>No image</span>
                                    }
                                </td>
                                <td>@food.Name</td>
                                <td>@(food.Category?.Name ?? "N/A")</td>
                                <td>@food.Price.ToString("N0") VND</td>
                                <td>
                                    <span class="badge @((food.IsAvailable ? "bg-label-success" : "bg-label-danger"))">
                                        @(food.IsAvailable ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <div class="dropdown">
                                        <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                            <i class="bx bx-dots-vertical-rounded"></i>
                                        </button>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@food.FoodItemId">
                                                <i class="bx bx-edit-alt me-1"></i> Edit
                                            </a>
                                            @if (food.IsAvailable)
                                            {
                                                <form asp-area="Admin" asp-controller="Food" asp-action="Deactive" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@food.FoodItemId" />
                                                    <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Are you sure you want to deactivate this food?');">
                                                        <i class="bx bx-trash me-1"></i> Deactivate
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-area="Admin" asp-controller="Food" asp-action="Active" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@food.FoodItemId" />
                                                    <button type="submit" class="dropdown-item text-success" onclick="return confirm('Are you sure you want to activate this food?');">
                                                        <i class="bx bx-check-circle me-1"></i> Activate
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            @if (Model.TotalPage > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= Model.TotalPage; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", "Food", new { page = i, keyword = Model.Filter.Keyword, categoryId = Model.Filter.categoryID, priceFrom = Model.Filter.PriceFrom, priceTo = Model.Filter.PriceTo, sortBy = Model.Filter.SortBy, sortOrder = Model.Filter.SortOrder })">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>