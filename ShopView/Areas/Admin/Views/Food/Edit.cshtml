@using ShopDAL.Models
@model FoodItem

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4">
        <span class="text-muted fw-light">Admin/</span> Food Management
    </h4>

    <div class="card">
        <h5 class="card-header">Edit Food #@Model.FoodItemId</h5>
        <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ErrorMessage"]
                </div>
            }

            <form asp-area="Admin" asp-action="Edit" asp-controller="Food" asp-route-id="@Model.FoodItemId" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="FoodItemId" />
                <input type="hidden" asp-for="CreateDate" />
                <input type="hidden" asp-for="ImagePath" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter food name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter description"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label">Category</label>
                    @Html.DropDownListFor(model => model.CategoryId,
                             new SelectList((IEnumerable<SelectListItem>)ViewBag.Categories ?? new List<SelectListItem>(), "Value", "Text"),
                             "Select Category",
                             new { @class = "form-select" })
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Enter price" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Current Image</label>
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div>
                            <img src="@((ViewBag.ImageBaseUrl ?? "") + Model.ImagePath)" alt="Food Image" class="img-fluid rounded" style="max-height: 150px; margin-bottom: 10px;" />
                            <p>Current File: <strong>@System.IO.Path.GetFileName(Model.ImagePath)</strong></p>
                        </div>
                    }
                    else
                    {
                        <p>No image uploaded yet.</p>
                    }
                </div>

                <div class="mb-3">
                    <label for="formFile" class="form-label">Upload New Image</label>
                    <input type="file" class="form-control" id="formFile" name="formFile" accept="image/*" />
                    <small class="form-text text-muted">Leave empty if you don't want to change the image.</small>
                </div>

                <div class="mb-3">
                    <label asp-for="IsAvailable" class="form-label">Status</label>
                    <div class="form-check">
                        <input asp-for="IsAvailable" class="form-check-input" type="radio" value="true" />
                        <label class="form-check-label">Active</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="IsAvailable" class="form-check-input" type="radio" value="false" />
                        <label class="form-check-label">Inactive</label>
                    </div>
                </div>

                <div class="text-end">
                    <button type="submit" class="btn btn-primary">Update</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
