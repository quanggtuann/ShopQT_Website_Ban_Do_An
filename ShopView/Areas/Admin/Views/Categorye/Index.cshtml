@using ShopDAL.Models
@model IEnumerable<Category>

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4">
        <span class="text-muted fw-light">Admin/</span> Category Management
    </h4>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="text-end mb-4">
        <a href="/Admin/Categorye/Create" class="btn btn-primary">
            <i class="bx bx-plus me-1"></i> Create New Category
        </a>
    </div>

    <div class="card">
        <h5 class="card-header">Category List</h5>
        <div class="table-responsive text-nowrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @foreach (var category in Model)
                    {
                        <tr>
                            <td>@category.CategoryId</td>
                            <td>@category.Name</td>
                            <td>
                                <span class="badge @((category.IsActive ? "bg-label-success" : "bg-label-danger"))">
                                    @(category.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                        <i class="bx bx-dots-vertical-rounded"></i>
                                    </button>
                                    <div class="dropdown-menu">
                                        <a class="dropdown-item" asp-action="Edit" asp-route-id="@category.CategoryId">
                                            <i class="bx bx-edit-alt me-1"></i> Edit
                                        </a>
                                        @if (category.IsActive)
                                        {
                                            <form asp-area="Admin" asp-controller="Categorye" asp-action="Deaction" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@category.CategoryId" />
                                                <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Are you sure you want to deactivate this category?');">
                                                    <i class="bx bx-trash me-1"></i> Deactivate
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-area="Admin" asp-controller="Categorye" asp-action="Action" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@category.CategoryId" />
                                                <button type="submit" class="dropdown-item text-success" onclick="return confirm('Are you sure you want to activate this category?');">
                                                    <i class="bx bx-check-circle me-1"></i> Activate
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
