@using ShopView.Models
@model ComboIndexViewModel

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4">
        <span class="text-muted fw-light">Admin/</span> Combo Management
    </h4>

    <div class="text-end mb-4">
        <a href="/Admin/Combo/Create" class="btn btn-primary">
            <i class="bx bx-plus me-1"></i> Create New Combo
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <!-- Filter Form -->
    <div class="filter-form p-4 mb-4 shadow-sm rounded bg-light">
        <form method="get" asp-action="Index" class="needs-validation">
            <h4 class="mb-4 text-primary text-center fw-bold">Filter Combos</h4>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Search by Name/Description:</label>
                    <input type="text" name="keyWord" class="form-control" placeholder="Enter keyword" value="@Model.Filter.KeyWord" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Price Range:</label>
                    <div class="input-group">
                        <input type="number" name="fromPrice" class="form-control border-end-0" placeholder="Min" value="@Model.Filter.FromPrice" />
                        <span class="input-group-text">to</span>
                        <input type="number" name="toPrice" class="form-control border-start-0" placeholder="Max" value="@Model.Filter.ToPrice" />
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Sort by:</label>
                    <select name="sortBy" class="form-select">
                        <option value="">-- Select --</option>
                        <option value="Name" selected="@(Model.Filter.ShortBy == "Name")">Name</option>
                        <option value="Price" selected="@(Model.Filter.ShortBy == "Price")">Price</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Sort Order:</label>
                    <select name="sortOrder" class="form-select">
                        <option value="asc" selected="@(Model.Filter.ShortOrder == "asc")">Ascending</option>
                        <option value="desc" selected="@(Model.Filter.ShortOrder == "desc")">Descending</option>
                    </select>
                </div>
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm me-2">
                    <i class="fa fa-filter"></i> Apply
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5 shadow-sm">
                    <i class="fa fa-redo"></i> Reset
                </a>
            </div>
        </form>
    </div>

    <!-- Combo List -->
    <div class="card">
        <h5 class="card-header">Combo List</h5>
        <div class="table-responsive text-nowrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Price</th>
                        <th>Food Items</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="table-border-bottom-0">
                    @if (Model.Combos != null && Model.Combos.Any())
                    {
                        @foreach (var combo in Model.Combos)
                        {
                            <tr>
                                <td>@combo.ComboId</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(combo.ImagePath))
                                    {
                                        <img src="@(Model.ImageBaseUrl + combo.ImagePath)" alt="Combo Image" class="rounded" style="width: 50px; height: 50px;" />
                                    }
                                    else
                                    {
                                        <span>No image</span>
                                    }
                                </td>
                                <td>@combo.Name</td>
                                <td>@(combo.Description?.Length > 50 ? combo.Description.Substring(0, 50) + "..." : combo.Description)</td>
                                <td>@combo.Price.ToString("N0") VND</td>
                                <td>
                                    @if (combo.FoodItems != null && combo.FoodItems.Any())
                                    {
                                        <small>
                                            @string.Join(", ", combo.FoodItems.Select(f => $"{f.FoodName} x{f.Quantity}"))
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @((combo.IsVaiLabel ? "bg-label-success" : "bg-label-danger"))">
                                        @(combo.IsVaiLabel ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <div class="dropdown">
                                        <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                            <i class="bx bx-dots-vertical-rounded"></i>
                                        </button>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@combo.ComboId">
                                                <i class="bx bx-edit-alt me-1"></i> Edit
                                            </a>
                                            @if (combo.IsVaiLabel)
                                            {
                                                <form asp-area="Admin" asp-controller="Combo" asp-action="Deactivate" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@combo.ComboId" />
                                                    <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Deactivate this combo?');">
                                                        <i class="bx bx-trash me-1"></i> Deactivate
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-area="Admin" asp-controller="Combo" asp-action="Activate" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@combo.ComboId" />
                                                    <button type="submit" class="dropdown-item text-success" onclick="return confirm('Activate this combo?');">
                                                        <i class="bx bx-check-circle me-1"></i> Activate
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No combos found</td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            @if (Model.TotalPage > 1)
            {
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center">
                        @for (int i = 1; i <= Model.TotalPage; i++)
                        {
                            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", "Combo", new { page = i, keyWord = Model.Filter.KeyWord, fromPrice = Model.Filter.FromPrice, toPrice = Model.Filter.ToPrice, sortBy = Model.Filter.ShortBy, sortOrder = Model.Filter.ShortOrder })">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
