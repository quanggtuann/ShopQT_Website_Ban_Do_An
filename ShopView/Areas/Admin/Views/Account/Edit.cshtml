@model ShopDAL.Models.User

<div class="container-xxl flex-grow-1 container-p-y">
    <h4 class="fw-bold py-3 mb-4">
        <span class="text-muted fw-light">Admin/Accounts/</span> Edit User
    </h4>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Edit Account #@Model.UserID</h5>
        </div>
        <div class="card-body">
            <form asp-area="Admin" asp-controller="Account" asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="UserID" />

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Username</label>
                    <input asp-for="Username" class="form-control" readonly disabled />
                    <input type="hidden" asp-for="Username" />
                    <small class="text-muted">Username cannot be changed</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter new password or leave blank" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                    <small class="text-muted">Leave blank to keep current password</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Enter email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" maxlength="10" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="form-label">Role</label>
                    <input asp-for="Role" class="form-control" readonly disabled />
                    <input type="hidden" asp-for="Role" />
                    <small class="text-muted">Role cannot be changed</small>
                </div>

                <div class="mb-3">
                    <label asp-for="DateorBirth" class="form-label">Date of Birth</label>
                    <input asp-for="DateorBirth" type="date" class="form-control" />
                    <span asp-validation-for="DateorBirth" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Active</label>
                    </div>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-area="Admin" asp-controller="Account" asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
